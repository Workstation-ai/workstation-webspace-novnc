#!/bin/bash
# workstation-webspace-novnc: Show status
echo "=== workstation-webspace-novnc ==="

if pidof systemd > /dev/null 2>&1; then
  for svc in bux-xvfb bux-fluxbox bux-x11vnc bux-novnc bux-novnc-tunnel; do
    status=$(systemctl is-active "$svc" 2>/dev/null || echo "unknown")
    printf "  %-25s %s\n" "$svc" "$status"
  done
else
  echo "  Xvfb:              $(pgrep -f 'Xvfb :99' > /dev/null && echo 'running' || echo 'stopped')"
  echo "  fluxbox:           $(pgrep -f 'fluxbox -display :99' > /dev/null && echo 'running' || echo 'stopped')"
  echo "  x11vnc:            $(pgrep -f 'x11vnc -display :99' > /dev/null && echo 'running' || echo 'stopped')"
  echo "  websockify:        $(pgrep -f 'websockify.*6080' > /dev/null && echo 'running' || echo 'stopped')"
  echo "  cloudflared:       $(pgrep -f 'cloudflared.*6080' > /dev/null && echo 'running' || echo 'stopped')"
fi

echo ""
if pidof systemd > /dev/null 2>&1; then
  URL=$(grep -o 'https://[a-zA-Z0-9-]*\.trycloudflare\.com' /var/log/bux/novnc-tunnel.log 2>/dev/null | tail -1)
else
  USER_HOME="$HOME"
  URL=$(grep -o 'https://[a-zA-Z0-9-]*\.trycloudflare\.com' "$USER_HOME/.workstation-webspace-novnc/logs/novnc-tunnel.log" 2>/dev/null | tail -1)
fi
echo "URL: ${URL:-N/A}"

# Show password from .env if available
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$SCRIPT_DIR/.env" ]; then
  source "$SCRIPT_DIR/.env"
  echo "Password: ${VNC_PASSWORD:-not set}"
else
  echo "Password: (no .env file)"
fi
