#!/bin/bash
# workstation-webspace-novnc: One-command setup
# Usage: ./run
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
USER_HOME="$HOME"
USER_NAME="$(whoami)"

# --- Load .env ---
if [ ! -f "$SCRIPT_DIR/.env" ]; then
  echo "Error: .env file not found."
  echo "Copy .env.example to .env and configure it:"
  echo "  cp .env.example .env"
  echo "  nano .env"
  exit 1
fi

source "$SCRIPT_DIR/.env"

if [ -z "${VNC_PASSWORD:-}" ]; then
  echo "Error: VNC_PASSWORD is not set in .env"
  exit 1
fi

RESOLUTION="${SCREEN_RESOLUTION:-1920x1080}"
DEPTH="${COLOR_DEPTH:-24}"
RES_X="${RESOLUTION%x*}"
RES_Y="${RESOLUTION#*x}"

NOVNC_DIR="/opt/noVNC"

# --- Check for systemd ---
USE_SYSTEMD=true
if ! pidof systemd > /dev/null 2>&1; then
  echo "Note: systemd not detected. Running in direct mode (no auto-restart)."
  USE_SYSTEMD=false
fi

echo "=== workstation-webspace-novnc ==="
echo "Resolution: ${RESOLUTION}x${DEPTH}bit"
echo "User: ${USER_NAME}"
echo ""

# --- Packages ---
echo "[1/6] Installing packages..."
sudo apt-get update -qq
sudo apt-get install -y -qq x11vnc fluxbox xfce4-terminal xdg-utils xsel dbus-x11 xdotool wmctrl 2>&1 | tail -3
pip3 install --break-system-packages websockify 2>&1 | tail -2

# --- cloudflared ---
if ! command -v cloudflared &> /dev/null; then
  echo "[1b/6] Installing cloudflared..."
  curl -sL "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64" -o /tmp/cloudflared
  chmod +x /tmp/cloudflared
  sudo mv /tmp/cloudflared /usr/local/bin/cloudflared
fi

# --- noVNC ---
if [ ! -d "$NOVNC_DIR" ]; then
  echo "[2/7] Cloning noVNC..."
  sudo git clone --depth 1 https://github.com/novnc/noVNC.git "$NOVNC_DIR"
else
  echo "[2/7] noVNC already installed, skipping"
fi

# --- Firefox (non-snap) ---
if [ ! -x /opt/firefox/firefox ]; then
  echo "[3/7] Installing Firefox..."
  curl -sL "https://download.mozilla.org/?product=firefox-latest&os=linux64&lang=en-US" -o /tmp/firefox.tar.bz2
  cd /opt && sudo tar xJf /tmp/firefox.tar.bz2
  sudo ln -sf /opt/firefox/firefox /usr/local/bin/firefox
else
  echo "[3/7] Firefox already installed, skipping"
fi

sudo ln -sf "$NOVNC_DIR/vnc.html" "$NOVNC_DIR/index.html"

# --- VNC Password ---
echo "[5/7] Setting VNC password..."
mkdir -p "$USER_HOME/.vnc"
x11vnc -storepasswd "$VNC_PASSWORD" "$USER_HOME/.vnc/passwd" 2>&1 | tail -1

# --- Fluxbox ---
echo "[6/7] Configuring desktop..."
mkdir -p "$USER_HOME/.fluxbox"

cat > "$USER_HOME/.fluxbox/menu" << 'MENU'
[begin] (Desktop)
	[submenu] (Applications)
		[exec] (Terminal) {xfce4-terminal} <>
		[exec] (Firefox) {/opt/firefox/firefox} <>
		[exec] (Text Editor) {xfce4-terminal -e nano} <>
	[end]
	[submenu] (System)
		[exec] (htop) {xfce4-terminal -e htop} <>
		[exec] (Disk Usage) {xfce4-terminal -e "df -h"} <>
		[exec] (Process List) {xfce4-terminal -e "ps aux"} <>
	[end]
	[submenu] (Network)
		[exec] (IP Info) {xfce4-terminal -e "curl -s ifconfig.me && echo && ip addr show"} <>
	[end]
	[separator]
	[restart] (Restart) <>
	[exit] (Exit) <>
end
MENU

cat > "$USER_HOME/.fluxbox/init" << EOF
! Toolbar
session.screen0.toolbar.visible: true
session.screen0.toolbar.widthPercent: 100
session.screen0.toolbar.maintainSize: true
session.screen0.toolbar.height: 32
session.screen0.toolbar.tools: prevworkspace, workspacename, nextworkspace, clock, prevwindow, nextwindow, iconbar, systemtray

! Iconbar
session.screen0.iconbar.mode: {static groups} (workspace=[current])

! Window placement
session.screen0.windowPlacement: UnderMouse
session.screen0.maxIgnorePositionBar: true

! Menu
session.screen0.menuFile: ~/.fluxbox/menu

! Workspace
session.screen0.workspaceCount: 1
EOF

# Keys with unminimize shortcut
cp /etc/X11/fluxbox/keys "$USER_HOME/.fluxbox/keys" 2>/dev/null || true
cat >> "$USER_HOME/.fluxbox/keys" << 'KEYS'

# unminimize all windows
Mod4 u :UnminimizeAll
KEYS

# --- Systemd services or direct mode ---
TUNNEL_LOG=""
if [ "$USE_SYSTEMD" = true ]; then
  echo "[7/7] Installing services..."
  sudo mkdir -p /var/log/bux
  TUNNEL_LOG="/var/log/bux/novnc-tunnel.log"
  sudo cp "$SCRIPT_DIR/scripts/services/"*.service /etc/systemd/system/

  # Update Xvfb resolution
  sudo sed -i "s/-screen 0 [0-9]*x[0-9]*x[0-9]*/-screen 0 ${RES_X}x${RES_Y}x${DEPTH}/" /etc/systemd/system/bux-xvfb.service
  sudo systemctl daemon-reload

  for svc in bux-xvfb bux-fluxbox bux-x11vnc bux-novnc bux-novnc-tunnel; do
    sudo systemctl enable "$svc" 2>/dev/null
  done
else
  echo "[7/7] Direct mode (no systemd)..."
  LOG_DIR="$USER_HOME/.workstation-webspace-novnc/logs"
  mkdir -p "$LOG_DIR"
  TUNNEL_LOG="$LOG_DIR/novnc-tunnel.log"
fi

# --- pbcopy/pbpaste ---
if ! grep -q "pbcopy" "$USER_HOME/.bashrc" 2>/dev/null; then
  cat >> "$USER_HOME/.bashrc" << 'EOF'

# Linux version of OSX pbcopy and pbpaste.
alias pbcopy='xsel --clipboard --input'
alias pbpaste='xsel --clipboard --output'
EOF
fi

# --- Start ---
echo ""
echo "Starting services..."

if [ "$USE_SYSTEMD" = true ]; then
  sudo truncate -s 0 /var/log/bux/novnc-tunnel.log 2>/dev/null || true
  for svc in bux-xvfb bux-fluxbox bux-x11vnc bux-novnc bux-novnc-tunnel; do
    sudo systemctl start "$svc" 2>/dev/null || true
  done
else
  # Direct mode: run processes in background
  truncate -s 0 "$TUNNEL_LOG" 2>/dev/null || true

  # Kill any existing processes
  pkill -f "Xvfb :99" 2>/dev/null || true
  pkill -f "fluxbox -display :99" 2>/dev/null || true
  pkill -f "x11vnc -display :99" 2>/dev/null || true
  pkill -f "websockify.*6080" 2>/dev/null || true
  pkill -f "cloudflared.*6080" 2>/dev/null || true
  sleep 1

  # Start processes
  Xvfb :99 -screen 0 "${RES_X}x${RES_Y}x${DEPTH}" -ac &
  sleep 1
  DISPLAY=:99 fluxbox &
  sleep 1
  DISPLAY=:99 x11vnc -display :99 -forever -shared -rfbauth "$USER_HOME/.vnc/passwd" -rfbport 5900 -noxdamage -noxrecord -noxfixes &
  sleep 1
  WEBSOCKIFY=$(which websockify 2>/dev/null || echo "$USER_HOME/.local/bin/websockify")
  "$WEBSOCKIFY" --web "$NOVNC_DIR" 6080 localhost:5900 > /dev/null 2>&1 &
fi

sleep 2

# --- Try cloudflared (optional - for environments without port forwarding) ---
CF_URL=""
if command -v cloudflared &> /dev/null; then
  echo ""
  echo "Attempting cloudflare tunnel..."
  truncate -s 0 "$TUNNEL_LOG" 2>/dev/null || true
  cloudflared tunnel --no-autoupdate --url http://127.0.0.1:6080 > "$TUNNEL_LOG" 2>&1 &
  CF_PID=$!
  
  # Wait up to 15 seconds for URL
  for i in $(seq 1 15); do
    CF_URL=$(grep -o 'https://[a-zA-Z0-9-]*\.trycloudflare\.com' "$TUNNEL_LOG" 2>/dev/null | tail -1)
    if [ -n "$CF_URL" ]; then
      break
    fi
    if ! kill -0 $CF_PID 2>/dev/null; then
      echo "cloudflared process exited - using local port forwarding instead"
      break
    fi
    sleep 1
  done
fi

# --- Print access info ---
echo ""
echo "=== Ready ==="
echo ""
if [ -n "$CF_URL" ]; then
  echo "Cloudflare URL: $CF_URL"
  echo ""
  echo "Or use direct access:"
fi
echo "Local URL:  http://localhost:6080"
echo "VNC direct: vnc://localhost:5900"
echo ""
echo "Password:   ${VNC_PASSWORD}"
echo ""
echo "--- How to access ---"
echo "1. In Codespaces: click the 'Ports' tab, find port 6080, click the globe icon"
echo "2. Or open: http://localhost:6080 in your browser"
echo "3. Enter the password when prompted"
