#!/bin/bash
# workstation-webspace-novnc: Uninstall cleanly
set -euo pipefail
echo "=== Uninstalling ==="

echo "[1/4] Stopping services..."
for svc in bux-novnc-tunnel bux-novnc bux-x11vnc bux-fluxbox bux-xvfb; do
  sudo systemctl stop "$svc" 2>/dev/null || true
  sudo systemctl disable "$svc" 2>/dev/null || true
done

echo "[2/4] Removing services..."
sudo rm -f /etc/systemd/system/bux-{xvfb,fluxbox,apps,x11vnc,novnc,novnc-tunnel}.service
sudo systemctl daemon-reload

echo "[3/4] Removing files..."
sudo rm -rf /opt/noVNC /opt/firefox /usr/local/bin/firefox
rm -rf /home/bux/.fluxbox /home/bux/.vnc /home/bux/.mozilla
rm -rf /home/bux/.config/mozilla /home/bux/.config/xfce4
rm -rf /var/log/bux/novnc-tunnel.log

echo "[4/4] Cleaning .bashrc..."
sed -i '/Linux version of OSX pbcopy/,/pbpaste/d' /home/bux/.bashrc 2>/dev/null || true

echo ""
echo "Done. Packages (x11vnc, fluxbox, etc.) were not removed."
